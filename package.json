{
  "name": "gemini-commit-wizard",
  "version": "1.2.8",
  "description": "AI-powered Git commit generation with multi-provider support (Gemini, Groq, OpenRouter)",
  "main": "src/commit-generator.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/commit-ui.ts"
  },
  "scripts": {
    "commit": "bun src/commit-ui.ts",
    "commit:quick": "bun src/commit-ui.ts --quick",
    "commit:manual": "bun src/commit-generator.ts",
    "commit:auto": "bun src/commit-generator.ts --auto-approve",
    "commit:dry": "bun src/commit-generator.ts --dry-run",
    "version": "bun src/version-manager.ts",
    "version:minor": "bun src/version-manager.ts --type minor",
    "version:major": "bun src/version-manager.ts --type major",
    "version:patch": "bun src/version-manager.ts --type patch",
    "version:alpha": "bun src/version-manager.ts --prefix alpha",
    "version:beta": "bun src/version-manager.ts --prefix beta",
    "version:sync": "bun src/version-manager.ts --sync",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "gemini",
    "groq",
    "openrouter",
    "claude",
    "llama",
    "multi-provider",
    "automation",
    "cli",
    "typescript",
    "bun",
    "developer-tools"
  ],
  "author": "MKS2508",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MKS2508/gemini-commit-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/MKS2508/gemini-commit-wizard/issues"
  },
  "homepage": "https://github.com/MKS2508/gemini-commit-wizard#readme",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.87",
    "@google/genai": "^1.47.0",
    "@inquirer/prompts": "^8.3.2",
    "@mks2508/better-logger": "^5.0.2",
    "@mks2508/no-throw": "^0.1.0",
    "@openrouter/sdk": "^0.10.2",
    "groq-sdk": "^1.1.2",
    "octokit": "^5.0.5",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src/**/*",
    ".run/**/*",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "bin": {
    "gemini-commit": "./src/commit-ui.ts",
    "gemini-commit-gen": "./src/commit-generator.ts",
    "gemini-version": "./src/version-manager.ts"
  }
}
